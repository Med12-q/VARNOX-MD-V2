# VARNOX-MD-V2 — Configuration

# WhatsApp Bot
OWNER_NUMBER=212600000000      # Your phone number without + (e.g. 212612345678)
BOT_PREFIX=.                   # Default command prefix

# Optional: AI Commands
OPENAI_API_KEY=                # OpenAI API key for .gpt, .imagine, etc.
AI_API_KEY=                    # Alternative AI provider key

# Optional: Download Commands
DOWNLOAD_API_KEY=              # API key for download services

# Optional: Tools
WEATHER_API_KEY=               # OpenWeatherMap API key for .weather

# GitHub (set automatically via Replit Secrets)
GITHUB_TOKEN=                  # GitHub PAT with repo write access

# Database (auto-configured by Replit)
DATABASE_URL=                  # PostgreSQL connection string
